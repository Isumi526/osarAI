# =====================================================================
# osarAI 環境変数サンプル（§13）
# このファイルをコピーして `.env` を作り、実値を記入する。
# `.env` は .gitignore 済み。コミットしないこと。
#
# 鉄則：service_role / GEMINI / STRIPE_SECRET は「サーバーのみ」。
#       クライアント（mobile/web のブラウザ）に絶対に出さない。
#       NEXT_PUBLIC_ / VITE_ 接頭辞はバンドルに焼き込まれ公開される＝公開可の値のみ。
# =====================================================================

# ---------- Supabase ----------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=            # ★サーバーのみ（RLSバイパス・Webhook更新用）
SUPABASE_PROJECT_REF=                 # supabase link 用

# クライアント公開用（同じ値を接頭辞付きで。anon までは公開可）
# web (Next.js)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# mobile (Vite)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_API_BASE_URL=                    # Web API のベースURL（dev: http://localhost:3000 / 本番: VercelのURL）
VITE_LP_ORIGIN=                       # 紹介リンクのLPオリジン（未設定時はVITE_API_BASE_URLにフォールバック。独自ドメイン確定後に設定）

# ---------- Gemini ----------
GEMINI_API_KEY=                       # ★サーバーのみ（モバイルから直接叩かない）
GEMINI_MODEL_DIALOGUE=                # 任意。おさらい対話用（既定: gemini-flash-latest）
GEMINI_MODEL_LITE=                    # 任意。抽出/要約/相談用の安価モデル（既定: gemini-flash-lite-latest）

# ---------- Stripe ----------
STRIPE_SECRET_KEY=                    # ★サーバーのみ
STRIPE_WEBHOOK_SECRET=                # stripe listen で出る whsec_xxx
STRIPE_PRICE_LIGHT=                   # Light ¥1,980  （CLI出力 price_xxx を転記）
STRIPE_PRICE_STANDARD=                # Standard ¥3,980
STRIPE_PRICE_PRO=                     # Pro ¥6,980
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=   # 公開可（pk_xxx）

# ---------- Push (FCM HTTP v1) — 通知フェーズで使用 ----------
# ★サーバーのみ。Firebase コンソール → プロジェクト設定 → サービスアカウント →
#   「新しい秘密鍵を生成」でDLしたJSONを、生JSON か base64 で入れる。
#   iOS(APNs)は Firebase 側に APNs認証キー(.p8)を登録すれば FCM 経由で届く。
FCM_SERVICE_ACCOUNT=
# （旧 FCM_SERVER_KEY / APNS_* は廃止。v1 では上記サービスアカウントに一本化）
